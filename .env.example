# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Required: change this to a long random string for production
SECRET_KEY=dev-secret-change-me

# SQLite path (default: journal.db in repo root for local dev)
# DATABASE_URL=sqlite:///journal.db

# Optional: personalise the journal header
JOURNAL_TITLE=My Journal
JOURNAL_OWNER=yourname
JOURNAL_SUBTITLE=
